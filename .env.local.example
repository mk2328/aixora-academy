# ── Supabase (FREE) ──────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App Config ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AIXORA Academy

# ── Resend Email (FREE - 3000 emails/month) ───────────────
# Get from: https://resend.com
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@aixora.academy

# ── Cloudinary (optional - for image optimization) ───────
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
